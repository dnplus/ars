{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "lib": ["ES2022", "DOM"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noUnusedLocals": false,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "react": ["node_modules/@types/react"]
      // theme 別名已移除 - 依賴 Webpack 動態解析
    }
  },
  "include": ["src", "cli", "extensions"],
  "exclude": [
    "remotion.config.ts"
  ]
}
