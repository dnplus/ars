# MiniMax TTS
# Required when src/episodes/<series>/series-config.ts uses speech.provider = "minimax".
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
# Provide one of these voice identifiers for MiniMax voice selection.
MINIMAX_VOICE_ID=
MINIMAX_CLONE_ID=
# Optional: override MiniMax API endpoint (default: https://api-uw.minimax.io/v1/t2a_v2)
MINIMAX_API_URL=

# VoxCPM TTS (self-hosted, OpenAI-compatible server e.g. vLLM-Omni)
# Required when src/episodes/<series>/series-config.ts uses speech.provider = "voxcpm".
# Example: vllm serve openbmb/VoxCPM2 --omni --port 8000
VOXCPM_API_BASE=
# Optional bearer token if the server is behind auth.
VOXCPM_API_KEY=

# YouTube publishing
# Required only when .ars/config.json enables publish.youtube.
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
