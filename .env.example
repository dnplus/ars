# MiniMax TTS
# Required only when .ars/config.json uses tts.provider = "minimax".
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
# Provide one of these voice identifiers for MiniMax voice selection.
MINIMAX_VOICE_ID=
MINIMAX_CLONE_ID=
# Optional: override MiniMax API endpoint (default: https://api-uw.minimax.io/v1/t2a_v2)
MINIMAX_API_URL=

# YouTube publishing
# Required only when .ars/config.json enables publish.youtube.
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
