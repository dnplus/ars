{
  "name": "agentic-remotion-studio",
  "version": "1.0.0",
  "description": "Turn ideas into published video episodes — fully agentic, Claude Code native, Remotion-powered",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dnplus/ars.git"
  },
  "homepage": "https://github.com/dnplus/ars#readme",
  "bugs": {
    "url": "https://github.com/dnplus/ars/issues"
  },
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "files": [
    "README.md",
    "LICENSE",
    "persona.md",
    ".env.example",
    "cli/bin/",
    "cli/commands/",
    "cli/index.ts",
    "cli/lib/",
    "cli/pronunciation_dict.yaml",
    "plugin/.claude-plugin/",
    "plugin/agents/",
    "plugin/hooks/",
    "plugin/scripts/",
    "plugin/skills/",
    ".github/workflows/",
    "src/",
    "public/shared/",
    "public/episodes/template/shared/",
    "eslint.config.mjs",
    "remotion.config.ts",
    "vite.studio.config.ts",
    "tsconfig.json"
  ],
  "dependencies": {
    "@dagrejs/dagre": "^2.0.4",
    "@remotion/cli": "4.0.435",
    "@remotion/google-fonts": "4.0.435",
    "@remotion/media": "4.0.435",
    "@remotion/renderer": "4.0.435",
    "dotenv": "^17.4.2",
    "mermaid": "^11.12.2",
    "prism-react-renderer": "^2.4.1",
    "puppeteer-core": "^24.40.0",
    "qrcode.react": "^4.2.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "react-native-web": "^0.21.2",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remotion": "4.0.435",
    "tsx": "^4.20.6",
    "typescript": "5.9.3",
    "youtube-transcript": "^1.3.1"
  },
  "devDependencies": {
    "@remotion/eslint-config-flat": "4.0.435",
    "@remotion/player": "4.0.435",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^22.0.0",
    "@types/react": "19.2.7",
    "@types/web": "^0.0.345",
    "@vitejs/plugin-react": "^5.1.3",
    "eslint": "9.19.0",
    "vite": "^7.3.1",
    "vitest": "^3.2.4"
  },
  "bin": {
    "ars": "./cli/bin/ars.js"
  },
  "scripts": {
    "ars": "tsx cli/index.ts",
    "postinstall": "node ./cli/bin/ars.js postinstall",
    "dev": "remotion studio",
    "build": "remotion bundle",
    "upgrade": "remotion upgrade",
    "lint": "eslint src && tsc",
    "test": "vitest run",
    "dev:studio": "vite --config vite.studio.config.ts",
    "build:studio": "vite build --config vite.studio.config.ts",
    "preview:studio": "vite preview --config vite.studio.config.ts"
  },
  "sideEffects": [
    "*.css"
  ]
}
